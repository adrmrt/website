---
import type { GetStaticPathsOptions } from "astro";
import { getCollection } from "astro:content";
import PostItem from "../../components/blog/PostItem.astro";
import Headline from "../../components/ui/Headline.astro";
import Pagination from "../../components/ui/Pagination.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const blogEntries = await getCollection("blog");
  const sortedPosts = blogEntries
    .filter((post) => post.data && post.data.pubDate)
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

  return paginate(sortedPosts, { pageSize: 10 });
}

const { page } = Astro.props;
const blog = page.data;

const metadata = {
  title: "Blog",
  description: "Where I share my thoughts and insights.",
};
---

<BaseLayout metadata={metadata}>
  <section class="relative px-4 sm:px-6 lg:px-8">
    <div class="relative mx-auto max-w-4xl">
      <Headline
        title="Blog"
        classes={{
          container: "mt-8 text-center",
          title:
            "font-heading mb-12 text-4xl font-bold tracking-tight text-foreground md:text-6xl",
          subtitle: "mx-auto max-w-3xl text-xl text-muted-foreground",
        }}
      />

      <div class="flex flex-col gap-4 mb-4">
        {blog.map((post) => <PostItem post={post} />)}
      </div>
      <Pagination page={page} />
    </div>
  </section>
</BaseLayout>
