---
import { getImage } from "astro:assets";
import aboutImage from "../assets/images/about.jpeg";
import Content from "../components/widgets/Content.astro";
import Content2 from "../components/widgets/Content2.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const metadata = {
  title: "About",
  description:
    "Learn more about me, my background, and the purpose of this website.",
};

const optimizedImage = await getImage({
  src: aboutImage,
  format: "jpeg",
});
---

<BaseLayout {metadata}>
  <link slot="head" rel="preload" href={optimizedImage.src} as="image" />
  <Content2
    title="About Me"
    description={[
      "I'm Adrian, a software engineer based in Switzerland. I'm currently finishing my BSc in Computer Science at ZHAW School of Engineering, where I specialize in Software Engineering and Artifical Intelligence.",
      "I enjoy working across the full stack, with a particular interest in clean software architecture and design. I have experience with a variety of technologies, including TypeScript, Python, and Java, and I'm always eager to learn new tools and frameworks.",
    ]}
    image={aboutImage}
    imageAlt="Have this image until I find a better one >:)"
  />

  <Content
      title="About this Website"
      description={[
        "This site is my personal corner of the internet. I use it to share things I'm learning, document projects I'm working on, and occasionally write about topics that interest me.",
        "It's built with Astro and Tailwind CSS and deployed on Cloudflare Pages. The source code is in my GitHub repository if you are curious."
      ]}
  />
</BaseLayout>
