---
import { siteConfig } from "../../config/site";
---

<footer class="border-t border-border bg-card">
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="text-center text-xs text-muted-foreground">
      <p>&copy; {new Date().getFullYear()} {siteConfig.author}</p>
      <p>
        Built with <a
          href="https://astro.build"
          class="underline hover:text-foreground">Astro</a
        > · Based on <a
          href="https://github.com/devgelo-labs/astro-starter-pro"
          class="underline hover:text-foreground">Astro Starter Pro</a
        >
      </p>
    </div>
  </div>
</footer>
