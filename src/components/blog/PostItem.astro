---
import { type CollectionEntry } from "astro:content";
import { getReadingTime, getWordCount } from "../../utils/postUtils";

export interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;

const wordCount = getWordCount(post);

const readingTime = getReadingTime(post);
---

<article
  class="reveal group relative flex flex-col overflow-hidden rounded-xl border border-border bg-card shadow-sm transition-all duration-300 hover:shadow-lg hover:shadow-primary/5"
>
  <a href={`/blog/${post.id}`} class="flex flex-1 flex-col gap-3 p-5">
    <div class="flex-1">
      <p class="text-xl font-semibold text-foreground group-hover:underline">
        {post.data.title}
      </p>
    </div>
    <div class="flex items-center">
      <div class="flex space-x-1 text-sm text-muted-foreground">
        <time datetime={post.data.pubDate.toISOString()}>
          {
            post.data.pubDate.toLocaleDateString("en-US", {
              year: "numeric",
              month: "long",
              day: "numeric",
              timeZone: "UTC",
            })
          }
        </time>
        {wordCount && <span>&bull; {wordCount} words</span>}
        {readingTime && <span>&bull; {readingTime} min read</span>}
      </div>
    </div>
  </a>
</article>
